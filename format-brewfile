#!/usr/bin/ruby

keys = []
values = []

ARGF.each do |line|
  line.chomp!

  key = line.split.first
  value = []

  if index = keys.index(key)
    value = values[index]
  else
    keys << key
    values << value
  end

  value << line
end

values.each do |value|
  value.sort.each do |line|
    puts line
  end
end
