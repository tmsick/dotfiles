#!/bin/bash

# Usage: $ eval $(go2univ)

set -Ceu -o pipefail

readonly root="$HOME/Documents/Univ"

year="$(date '+%Y')"
season=""

readonly month="$(date '+%m')"
case "$month" in
"01" | "02" | "03")
    season="Fall"
    ((year--))
    ;;
"04" | "05" | "06" | "07" | "08" | "09")
    season="Spring"
    ;;
"10" | "11" | "12")
    season="Fall"
    ;;
esac

readonly dist="$root/$year/$season"

if [[ -e "$dist" ]]; then
    if [[ -d "$dist" ]]; then
        echo "cd '$dist'"
    else
        echo "ERROR: '$dist', which is not a directory, exists" >&2
        exit 1
    fi
else
    if mkdir -p "$dist"; then
        echo "cd '$dist'"
    else
        echo "ERROR: Failed to make '$dist'" >&2
        exit 1
    fi
fi
