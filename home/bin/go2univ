#!/bin/bash

# Usage: $ eval $(go2univ)

set -Ceu -o pipefail

readonly RESET="$(printf '\033[m')"
readonly RED="$(printf '\033[31m')"

function error() {
    echo $RED"$@"$RED >&2
}

readonly root="$HOME/Documents/Univ"

year="$(date '+%Y')"
season=""

readonly month="$(date '+%m')"
case "$month" in
"01" | "02" | "03")
    season="Fall"
    ((year--))
    ;;
"04" | "05" | "06" | "07" | "08" | "09")
    season="Spring"
    ;;
"10" | "11" | "12")
    season="Fall"
    ;;
esac

readonly dist="$root/$year/$season"

if [[ -e "$dist" ]]; then
    if [[ -d "$dist" ]]; then
        echo "cd '$dist'"
    else
        error "'$dist', which is not a directory, exists"
        exit 1
    fi
else
    if mkdir -p "$dist"; then
        echo "cd '$dist'"
    else
        error "Failed to make '$dist'"
        exit 1
    fi
fi
