#!/usr/bin/env python3

PROGRAM_NAME = "password"
DEFAULT_PASSWD_LENGTH = 32


def gen_passwd(length: int, capital=False) -> str:
    import secrets

    generator = secrets.SystemRandom()
    random = generator.randrange(0, 0x10 ** length)
    template = "{:0%dx}" % length
    return template.format(random)


def parse_args():
    from argparse import ArgumentParser

    parser = ArgumentParser(prog=PROGRAM_NAME, description="Generate a password.")
    parser.add_argument("-n", action="store_true", help="do not output a newline")
    parser.add_argument(
        "-l",
        nargs=1,
        default=[DEFAULT_PASSWD_LENGTH],
        type=int,
        help="password length (default: {})".format(DEFAULT_PASSWD_LENGTH),
    )
    parser.add_argument(
        "-U", action="store_true", help="generate AN UPPER-CASED PASSWORD"
    )
    return vars(parser.parse_args())


def main():
    args = parse_args()
    passwd = gen_passwd(args["l"][0])
    if args["U"]:
        passwd = passwd.upper()
    print(passwd, end=("" if args["n"] else "\n"))


if __name__ == "__main__":
    main()
