#!/usr/bin/env python3

from secrets import randbelow
from sys import argv, stderr
from re import match

length = 0
if len(argv) > 1:
    length_str = argv[1]
    if match('^[0-9]+$', length_str):
        length = int(length_str)
    else:
        print('Argument is invalid', file=stderr)
        exit(1)
else:
    length = 20

max = 0x10**length
pass_hex = randbelow(max)
password = '{:x}'.format(pass_hex).zfill(length)
print(password)
