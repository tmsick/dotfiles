#!/bin/bash

set -Ceu -o pipefail

readonly SCRIPT_NAME="$(basename "$0")"
readonly SCRIPT_DIR="$(dirname "$0")"
readonly SCRIPT_NAME_ABS="$PWD/$SCRIPT_DIR/$SCRIPT_NAME"
readonly SCRIPT_DIR_ABS="$PWD/$SCRIPT_DIR"

readonly DOTFILES_HOME="${DOTFILES_HOME:-"$HOME/.dotfiles"}"
readonly TEMPLATE_PATH="$DOTFILES_HOME/snippets/bash-script-header.sh"

function print_help() {
    cat <<EOS
Usage:
    $SCRIPT_NAME files...
EOS
}

function main() {
    if [[ $# -eq 0 ]]; then
        print_help >&2
        return 100
    fi

    if ! [[ -f "$TEMPLATE_PATH" ]]; then
        echo "template file '$TEMPLATE_PATH' doesn't exist" >&2
        return 200
    fi

    local status=0
    local arg=""
    local arg_abs=""

    for arg in "$@"; do
        arg_abs="$PWD/$arg"

        if [[ -e "$arg_abs" ]]; then
            echo "'$arg' already exists" >&2
            status=1
            continue
        fi

        cat "$TEMPLATE_PATH" >"$arg_abs"
        chmod +x "$arg_abs"
    done

    return $status
}

main "$@"
