[alias]
br = branch
cm = commit
co = checkout
st = status

[color]
ui = auto

[commit]
gpgsign = true

[filter "lfs"]
required = true
process = git-lfs filter-process
clean = git-lfs clean -- %f
smudge = git-lfs smudge -- %f

[url "git@github.com:"]
InsteadOf = https://github.com/

