# vim: set noexpandtab:

[alias]
	ad  = add
	br  = branch
	cl  = clean
	cm  = commit
	co  = checkout
	df  = diff
	ds  = diff --staged
	lg  = log --oneline --graph
	mg  = merge
	pl  = pull
	ps  = push
	rb  = rebase
	rmc = rm --cached
	rs  = reset
	st  = status --short

[color]
	ui = auto

[commit]
	gpgsign = true

[core]
	excludesfile = ~/.gitignore_global

[url "git@github.com:"]
	InsteadOf = https://github.com/

[user]
	email      = tomoya.y@icloud.com
	name       = "Tomoya Yoshioka"
	signingkey = 29B6837670D094111FB1200C5E1B7273D8E42DB7
