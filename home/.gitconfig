[alias]
    br = branch
    cm = commit
    co = checkout
    st = status

[color]
    ui = auto

[commit]
    gpgsign = true

[core]
    excludesfile = ~/.gitignore_global

[filter "lfs"]
    required = true
    process = git-lfs filter-process
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f

[user]
    name = Tomoya Yoshioka
    email = tomoya.y@icloud.com
    signingkey = 29B6837670D094111FB1200C5E1B7273D8E42DB7

[url "git@github.com:"]
    InsteadOf = https://github.com/
