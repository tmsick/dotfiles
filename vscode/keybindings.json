[
  // Ctrl+Cmd+' to open new terminal
  {
    "key": "ctrl+cmd+'",
    "command": "workbench.action.terminal.new"
  },
  {
    "key": "ctrl+shift+`",
    "command": "-workbench.action.terminal.new"
  },
  // Cmd+' to toggle terminal
  {
    "key": "cmd+'",
    "command": "workbench.action.terminal.toggleTerminal"
  },
  {
    "key": "ctrl+`",
    "command": "-workbench.action.terminal.toggleTerminal"
  }
]
