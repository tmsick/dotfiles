{
  "C_Cpp.default.cStandard": "c11",
  "C_Cpp.default.cppStandard": "c++17",

  "editor.cursorSurroundingLines": 5,
  "editor.detectIndentation": true,
  "editor.fontFamily": "Fira Mono",
  "editor.formatOnSave": true,
  "editor.lineNumbers": "relative",
  "editor.minimap.enabled": false,
  "editor.rulers": [80],

  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,

  "go.useLanguageServer": true,

  "latex-workshop.latex.autoClean.run": "onBuilt",
  "latex-workshop.latex.clean.fileTypes": ["*.aux", "*.log"],
  "latex-workshop.latex.recipes": [
    {
      "name": "ptex2pdf",
      "tools": ["ptex2pdf"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "args": ["-l", "%DOC%"],
      "command": "ptex2pdf",
      "name": "ptex2pdf"
    }
  ],
  "latex-workshop.view.pdf.ref.viewer": "auto",
  "latex-workshop.view.pdf.viewer": "tab",

  "python.formatting.provider": "black",

  "telemetry.enableCrashReporter": false,
  "telemetry.enableTelemetry": false,

  "terminal.external.osxExec": "iTerm.app",
  "terminal.integrated.fontFamily": "Fira Mono for Powerline",
  "terminal.integrated.shell.osx": "/usr/local/bin/fish",

  "vim.easymotion": true,
  "vim.easymotionMarkerBackgroundColor": "red",
  "vim.easymotionMarkerFontFamily": "Fira Mono",
  "vim.easymotionMarkerFontSize": "12",
  "vim.easymotionMarkerFontWeight": "bold",
  "vim.easymotionMarkerHeight": 12,
  "vim.leader": ",",
  "vim.useSystemClipboard": true,
  "vim.vimrc.enable": true,
  "vim.vimrc.path": "$HOME/.vimrc",

  "window.zoomLevel": 0,

  "workbench.activityBar.visible": true,
  "workbench.iconTheme": "material-icon-theme",

  // tab size
  "editor.tabSize": 4,
  "[javascript,javascriptreact,typescript,typescriptreact,json,graphql,markdown,yaml,html,css,less,sass,ruby,erb]": {
    "editor.tabSize": 2
  },

  // formatter
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-docker"
  },
  "[javascript,javascriptreact,typescript,typescriptreact,json,graphql,markdown,yaml,html,css,less,sass]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
