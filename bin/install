#!/usr/bin/env bash

# ==================================> header <==================================
set -o errexit \
  -o noclobber \
  -o nounset \
  -o pipefail

readonly EXEC_PATH=$(realpath "$0")
readonly SCRIPT_NAME=$(basename "$EXEC_PATH")
readonly SCRIPT_DIR=$(dirname "$EXEC_PATH")
readonly REPO_ROOT=$(realpath "$SCRIPT_DIR/..")
readonly BIN_DIR="$REPO_ROOT/bin"
readonly LIB_DIR="$REPO_ROOT/lib"
readonly PROFILE_DIR="$REPO_ROOT/profile"

export readonly DOTFILES_PROFILE="$PROFILE_DIR/bash.profile"
# ==============================================================================

function echo_help() {
  cat <<EOS
THIS IS HELP TEXT
EOS
}

# Make sure the latest version of formulae are available
"$LIB_DIR/install_brew_formula.sh" "bash"

if [[ $# -eq 0 ]]; then
  echo_help 1>&2
  exit 1
fi

for arg; do
  case "$arg" in
    "dotfiles")
      "$LIB_DIR/install_dotfiles.sh"
      ;;
    "texlive_ja_fonts")
      "$LIB_DIR/install_texlive_ja_fonts.sh"
      ;;
    "help")
      echo_help
      exit 0
      ;;
    *)
      cat 1>&2 <<EOS
SCRIPT_NAME: line $LINENO: Invalid option '$arg'. Continue processing.
EOS
      ;;
  esac
done
